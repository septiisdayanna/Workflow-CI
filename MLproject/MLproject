name: Sleep_Disorder_Prediction

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 505}
      max_depth: {type: int, default: 35}
      dataset: {type: string, default: "Sleep_health_and_lifestyle_dataset_preprocessing/"}
    command: "python modelling.py {n_estimators} {max_depth} {dataset}"